generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  createdAt    DateTime   @default(now())
  analyses     Analysis[]
}

model Analysis {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  sourceType     String
  originalText   String
  fileName       String?
  recommendation String
  reasoning      String
  createdAt      DateTime @default(now())
  flags              Flag[]
  userAccepted       Boolean?
  employerReachedOut Boolean?
}

model Flag {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  severity    String?
}
